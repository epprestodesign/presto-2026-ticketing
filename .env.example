# Copy to `.env` and add your Unsplash access key for runtime imagery.
# Get one at https://unsplash.com/developers
# NOTE: this key is exposed in the client bundle — use a demo key for local dev /
# prototypes only. Do NOT set it in CI for the public GitHub Pages build.
VITE_UNSPLASH_ACCESS_KEY=

# Hosted imagery library (public URL; safe to commit). Unset = local fallback.
VITE_IMAGERY_URL=https://epprestodesign.github.io/presto-ds-imagery

# Google Maps JavaScript API key for the Hotel Map pattern.
# Get one at https://console.cloud.google.com (enable "Maps JavaScript API").
# NOTE: a Maps JS key is exposed in the client bundle by design — you MUST
# restrict it in Cloud Console by HTTP referrer + API. For the deployed build,
# store it as the GitHub Actions secret GOOGLE_MAPS_API_KEY (not in this file).
VITE_GOOGLE_MAPS_API_KEY=
