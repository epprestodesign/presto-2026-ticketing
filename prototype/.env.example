# Prototype environment — copy to `.env` for local dev (`.env` is git-ignored).
# In CI these are injected by the deploy workflow (Maps key from the repo secret).

# Hosted hotel imagery (public URL) — randomized photos on cards + map tooltips.
VITE_IMAGERY_URL=https://epprestodesign.github.io/presto-ds-imagery

# Google Maps JS key for the Hotel Map (Browse filters + map dialog). Get one in
# Google Cloud Console (enable "Maps JavaScript API"), restrict it by HTTP
# referrer, and paste it here. Leave blank to see the graceful no-key fallback.
VITE_GOOGLE_MAPS_API_KEY=

# Ticketmaster Discovery API v2 consumer key. NOTE: no VITE_ prefix on purpose —
# it is read only by vite.config.js (Node side) and injected into the /tm dev
# proxy, so it never ships in the client bundle. Get one at
# https://developer.ticketmaster.com/. Leave blank to run against fixtures only.
TICKETMASTER_API_KEY=
